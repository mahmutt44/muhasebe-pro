# Flask SaaS Muhasebe Uygulaması - Production Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri güncelleyin

# Flask Configuration
FLASK_ENV=production
ENV=production
SECRET_KEY=your-very-strong-secret-key-change-this-in-production

# PostgreSQL Database
POSTGRES_DB=muhasebe
POSTGRES_USER=muhasebe_user
POSTGRES_PASSWORD=your-secure-postgres-password

# Demo Admin Password (ilk kurulum için)
DEMO_ADMIN_PASSWORD=change_this_strong_password

# Database URL (otomatik oluşturulur, elle değiştirmeyin)
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
